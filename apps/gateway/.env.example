# AES-256 key for encrypting stored secrets (hex-encoded 32 bytes)
GATEWAY_ENCRYPTION_KEY=

# Redis connection URL for BullMQ job queues
REDIS_URL=

# Mainnet relay base URL — X402PaymentVerifier calls /settle on this host
RELAY_URL=https://x402-relay.aibtc.com

# Testnet relay base URL
TESTNET_RELAY_URL=https://x402-relay.aibtc.dev

# Moltbook API key for agent social presence
MOLTBOOK_API_KEY=

# Telegram Bot Token for notification delivery
TELEGRAM_BOT_TOKEN=
