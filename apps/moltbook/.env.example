# Redis connection
REDIS_URL=redis://localhost:6379

# HTTP server port
PORT=3003

# Shared secret between this service and gateway/web
SERVICE_SECRET=change-me-to-a-random-secret

# Gateway base URL for constructing links
GATEWAY_URL=http://localhost:3001

# AI content generation (optional — falls back to templates if not set)
# Provider: openai | anthropic | template
AI_PROVIDER=template
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Override default model (gpt-4o-mini for OpenAI, claude-haiku-4-5-20251001 for Anthropic)
AI_MODEL=
