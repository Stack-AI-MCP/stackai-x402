# ─── StackAI x402 SDK — Quickstart Environment Variables ─────────────────────
# Copy to .env and fill in at minimum STACKS_PRIVATE_KEY.
# Usage: pnpm tsx examples/quickstart.ts

# Your Stacks private key (64-char hex). Keep secret.
# Generate one: pnpm tsx -e "import {generateAgentWallet} from './src/index.js'; console.log(generateAgentWallet('testnet').privateKey)"
STACKS_PRIVATE_KEY=

# Gateway URL (default: local dev)
GATEWAY_URL=http://localhost:3001

# Network: mainnet or testnet
NETWORK=testnet

# Display name for the demo agent
AGENT_NAME=My Demo Agent

# Set true to see Telegram deep link in step 9
TELEGRAM_ENABLED=false
